{
  "extends": "./tsconfig.options.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@be-music/utils": ["./packages/utils/src/index.ts"],
      "@be-music/json": ["./packages/json/src/index.ts"],
      "@be-music/parser": ["./packages/parser/src/index.ts"],
      "@be-music/stringifier": ["./packages/stringifier/src/index.ts"],
      "@be-music/audio-renderer": ["./packages/audio-renderer/src/index.ts"],
      "@be-music/player": ["./packages/player/src/index.ts"],
      "@be-music/editor": ["./packages/editor/src/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "vite.package.config.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "dist", "coverage", "tmp"]
}
