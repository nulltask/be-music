{
  "name": "@be-music/player",
  "version": "0.1.0",
  "description": "CLI BMS player",
  "bin": {
    "bms-player": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build:bundle": "vite build",
    "build": "vite build && tsgo -b tsconfig.json",
    "build:sea": "tsx ../../scripts/build-sea.ts --package player",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "dev": "tsx --tsconfig ../../tsconfig.typecheck.json src/cli.ts",
    "typecheck": "tsgo -p tsconfig.typecheck.json --pretty",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "bench": "tsx --tsconfig ../../tsconfig.typecheck.json scripts/bench.ts"
  },
  "dependencies": {
    "@be-music/audio-renderer": "workspace:*",
    "@be-music/json": "workspace:*",
    "@be-music/parser": "workspace:*",
    "@be-music/utils": "workspace:*",
    "@uwx/libav.js-fat": "6.0.0-nightly.29.f420ff.ffmpeg.6.1.1",
    "alien-signals": "^3.1.2",
    "fast-bmp": "^4.0.1",
    "fast-png": "^8.0.0",
    "jpeg-js": "^0.4.4",
    "node-web-audio-api": "^1.0.8"
  },
  "devDependencies": {
    "postject": "^1.0.0-alpha.6"
  }
}
