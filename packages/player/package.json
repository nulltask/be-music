{
  "name": "@be-music/player",
  "version": "0.1.0",
  "description": "CLI BMS player",
  "bin": {
    "bms-player": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build && tsgo -b tsconfig.json --emitDeclarationOnly --force",
    "build:sea": "node ./scripts/build-sea.mjs",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "dev": "tsx --tsconfig ../../tsconfig.dev.json src/cli.ts"
  },
  "dependencies": {
    "@be-music/audio-renderer": "0.1.0",
    "@be-music/json": "0.1.0",
    "@be-music/parser": "0.1.0",
    "@be-music/utils": "0.1.0",
    "@uwx/libav.js-fat": "6.0.0-nightly.29.f420ff.ffmpeg.6.1.1",
    "bmp-ts": "^1.0.9",
    "jpeg-js": "^0.4.4",
    "node-web-audio-api": "^1.0.8",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "postject": "^1.0.0-alpha.6"
  }
}
