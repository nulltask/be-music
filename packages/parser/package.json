{
  "name": "@be-music/parser",
  "version": "0.1.0",
  "description": "BMS/BMSON parser",
  "bin": {
    "bms-parse": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build:bundle": "vite build",
    "build": "vite build && tsgo -b tsconfig.json",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "dev": "tsx --tsconfig ../../tsconfig.dev.json src/cli.ts",
    "typecheck": "tsgo -p tsconfig.typecheck.json --pretty",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "bench": "tsx --tsconfig ../../tsconfig.dev.json src/benchmark.ts",
    "bench:check": "pnpm run bench -- --check",
    "bench:update-baseline": "pnpm run bench -- --write-baseline"
  },
  "dependencies": {
    "@be-music/json": "workspace:*",
    "@be-music/utils": "workspace:*",
    "iconv-lite": "^0.7.0"
  }
}
