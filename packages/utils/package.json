{
  "name": "@be-music/utils",
  "version": "0.1.0",
  "description": "Shared utility helpers for be-music packages",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build:bundle": "tsdown",
    "build": "tsdown",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "typecheck": "tsgo -p tsconfig.typecheck.json --pretty",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "bench": "tsx --tsconfig ../../tsconfig.typecheck.json scripts/bench.ts"
  },
  "dependencies": {
    "isoworker": "^0.2.4"
  }
}
