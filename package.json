{
  "name": "be-music",
  "version": "0.1.0",
  "private": true,
  "description": "Be-Music tooling monorepo",
  "scripts": {
    "build": "pnpm -r --sort --workspace-concurrency=Infinity run build",
    "clean": "pnpm -r run clean",
    "typecheck": "pnpm -r --parallel run typecheck",
    "lint": "pnpm -r --parallel run lint",
    "lint:fix": "pnpm -r --parallel run lint:fix",
    "format": "pnpm -r --parallel run format",
    "format:check": "pnpm -r --parallel run format:check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "bench": "tsx --tsconfig tsconfig.typecheck.json scripts/bench/exports.ts",
    "bench:aggregate": "tsx --tsconfig tsconfig.typecheck.json scripts/bench/aggregate-results.ts",
    "bench:compare": "tsx --tsconfig tsconfig.typecheck.json scripts/bench/compare-results.ts",
    "player": "pnpm --filter @be-music/player run dev",
    "player:sea": "pnpm --filter @be-music/player run build:sea",
    "audio-renderer:sea": "pnpm --filter @be-music/audio-renderer run build:sea",
    "editor": "pnpm --filter @be-music/editor run dev",
    "audio-render": "pnpm --filter @be-music/audio-renderer run dev",
    "parse": "pnpm --filter @be-music/parser run dev",
    "stringify": "pnpm --filter @be-music/stringifier run dev"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@typescript/native-preview": "7.0.0-dev.20260308.1",
    "@vitest/coverage-v8": "^4.0.18",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "rimraf": "^6.0.1",
    "tinybench": "^6.0.0",
    "tsdown": "^0.21.3",
    "tsx": "^4.20.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
